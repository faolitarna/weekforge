# .env.template
# Required environment variables for Weekforge.
# Copy this to .env and fill in your values.

# Notion Integration Token (Tier-0 access)
NOTION_TOKEN=

# Notion Testing (For Step 0b minimal test graph)
# Prepare a test database in notion and place the ID here
NOTION_TEST_DB_ID=

# OpenAI API Key
OPENAI_API_KEY=

# Optional: override default model profile selection
FAST_PROFILE=gpt-5.4-nano
REASONING_PROFILE=gpt-5.4

# Optional: reduce output-token cost at the cost of less-polished phrasing
# CAVEMAN_MODE=false

# Notion Training Databases
# IDs of the Notion databases that back weekforge workflows.
NOTION_DB_TRAINING_SESSIONS=
NOTION_DB_TRAINING_WEEK_SUMMARIES=
NOTION_DB_TRAINING_TEMPLATES=

# Notion User Profile Page
# ID of the Notion page containing user profile (not a database).
NOTION_USER_PROFILE_PAGE_ID=
